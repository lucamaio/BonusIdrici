{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=bonus;Uid=root;Pwd=;AllowZeroDateTime=True;ConvertZeroDateTime=True"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information" 
    }
  },
  "LogCleanup": {
    "DirectoryPath": "wwwroot/log",
    "RetentionDays": 90,
    "CheckEveryHours": 24,
    "StateFilePath": "App_Data/log-cleanup.state"
  },
  "AllowedHosts": "*"
}
