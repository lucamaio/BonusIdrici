@{
    ViewData["Title"] = "Esplora tutti gli Account";
    var utenti = ViewBag.Utenti as IEnumerable<Models.User>;
    var utentiList = utenti?.ToList() ?? new List<Models.User>();
}

<main class="data-page">
    <section class="data-hero data-hero-blue">
        <div>
            <p>Gestione utenti</p>
            <h1>Utenti</h1>
            <span>Account abilitati ad accedere al sistema</span>
        </div>
        <div class="data-hero-actions">
            <a href="@Url.Action("Create", "Account")" class="btn data-primary-action">
                <i class="bi bi-plus-circle"></i>
                <span>Aggiungi utente</span>
            </a>
        </div>
    </section>

    <section class="data-stats-grid">
        <article class="data-stat-card stat-blue">
            <i class="bi bi-people-fill"></i>
            <span>Utenti registrati</span>
            <strong>@utentiList.Count</strong>
        </article>
        <article class="data-stat-card stat-red">
            <i class="bi bi-shield-lock-fill"></i>
            <span>Admin</span>
            <strong>@utentiList.Count(x => x.getRuolo() == "ADMIN")</strong>
        </article>
        <article class="data-stat-card stat-green">
            <i class="bi bi-person-check-fill"></i>
            <span>Operatori</span>
            <strong>@utentiList.Count(x => x.getRuolo() == "OPERATORE")</strong>
        </article>
    </section>

    <section class="data-table-card">
        <div class="data-table-header">
            <div>
                <p>Archivio utenti</p>
                <h2>Account, ruoli e profili</h2>
            </div>
            <span>Ricerca, ordinamento e paginazione attivi</span>
        </div>

        <div id="loadingBarContainer" style="display: none;">
            <div id="loadingBar" role="progressbar"></div>
        </div>

        @if (utentiList.Any())
        {
            <div class="table-responsive w-100" id="tableWrapper" style="display: none;">
                <table id="accountTable" class="table table-hover align-middle data-table w-100">
                    <thead>
                        <tr>
                            <th>Utente</th>
                            <th>Email</th>
                            <th>Cognome</th>
                            <th>Nome</th>
                            <th>Ruolo</th>
                            <th class="text-center">Azioni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var utente in utentiList)
                        {
                            var ruolo = utente.getRuolo();
                            var statusClass = ruolo switch
                            {
                                "ADMIN" => "status-danger",
                                "OPERATORE" => "status-success",
                                _ => "status-warning"
                            };

                            <tr>
                                <td>
                                    <div class="data-main-cell">
                                        <strong>@utente.Username</strong>
                                        <span>ID @utente.id</span>
                                    </div>
                                </td>
                                <td>@utente.Email</td>
                                <td>@utente.Cognome</td>
                                <td>@utente.Nome</td>
                                <td><span class="data-status @statusClass">@ruolo</span></td>
                                <td class="text-center">
                                    <a class="data-icon-button" title="Modifica profilo"
                                       href="@Url.Action("Modifica", "Account", new { id = utente.id })">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="data-empty-state">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Nessun utente trovato</strong>
                <span>Non risultano account registrati nel sistema.</span>
            </div>
        }
    </section>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#loadingBarContainer").show();
            var progress = 0;
            var interval = setInterval(function () {
                if (progress < 90) {
                    progress += 10;
                    $("#loadingBar").css("width", progress + "%");
                }
            }, 300);

            var accountTable = $('#accountTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                responsive: true,
                pageLength: 25,
                lengthMenu: [10, 25, 50, 100],
                language: { url: "https://cdn.datatables.net/plug-ins/2.0.8/i18n/it-IT.json" },
                dom: '<"d-flex justify-content-between align-items-center mb-3"l f>t<"row mt-3"<"col-sm-6"i><"col-sm-6 text-end"p>>',
                buttons: [],
                drawCallback: function (settings) {
                    var api = this.api();
                    var pages = api.page.info().pages;
                    if (pages <= 1) {
                        $(api.table().container()).find('.dataTables_paginate').hide();
                        $(api.table().container()).find('.dataTables_length').hide();
                    } else {
                        $(api.table().container()).find('.dataTables_paginate').show();
                        $(api.table().container()).find('.dataTables_length').show();
                    }
                }
            });

            accountTable.on('init', function () {
                clearInterval(interval);
                $("#loadingBar").css("width", "100%");
                setTimeout(function () {
                    $("#loadingBarContainer").fadeOut();
                    $("#tableWrapper").fadeIn();
                }, 500);
            });
        });
    </script>
}
