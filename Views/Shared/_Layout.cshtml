@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var idUser = session?.GetInt32("idUser");
    var username = session?.GetString("Username");
    var role = session?.GetString("Role");
    var isLogged = idUser.HasValue && idUser.Value > 0;
    var isAdmin = string.Equals(role, "ADMIN", StringComparison.OrdinalIgnoreCase);
    var isAdminPrincipale = isAdmin && idUser == 1;
    var canUseOperations = isLogged && (isAdmin || string.Equals(role, "OPERATORE", StringComparison.OrdinalIgnoreCase));
}

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BonusIdrici</title>

    <!-- ✅ CSS principali -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <!-- ✅ DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.2/css/responsive.bootstrap5.min.css" />

    <!-- ✅ CSS del progetto -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/footer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BonusIdrici2.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg app-navbar shadow-sm">
            <div class="container-fluid">
                <button class="app-menu-toggle" type="button" onclick="toggleSidebar()" aria-label="Apri menu laterale">
                    <i class="bi bi-layout-sidebar-inset"></i>
                </button>

                <a class="navbar-brand app-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="app-brand-mark"><i class="bi bi-droplet-fill"></i></span>
                    <span class="app-brand-text">
                        <strong>BonusIdrici</strong>
                        <small>Gestione pratiche</small>
                    </span>
                </a>

                <div class="navbar-collapse">
                    <ul class="navbar-nav ms-auto align-items-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Info">
                                <i class="fa-solid fa-circle-info me-1"></i> Info
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link app-user-menu dropdown-toggle fw-semibold d-flex align-items-center" href="#"
                               id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i>
                                <span>@(isLogged && !string.IsNullOrWhiteSpace(username) ? username : "Profilo")</span>
                                @if (!string.IsNullOrWhiteSpace(role))
                                {
                                    <em>@role</em>
                                }
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                                @if (isLogged)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Dettagli">
                                            <i class="bi bi-info-circle me-2"></i> Informazioni Utente
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger fw-semibold" asp-controller="Login" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                                        </a>
                                    </li>
                                }
                                else
                                {
                                    <li>
                                        <a class="dropdown-item text-primary fw-semibold" asp-controller="Login" asp-action="Index">
                                            <i class="bi bi-box-arrow-in-right me-2"></i> Login
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <aside class="sidebar" id="sidebar" aria-label="Menu laterale">
            <div class="sidebar-header">
                <div>
                    <span class="sidebar-kicker">Menu</span>
                    <strong>BonusIdrici</strong>
                </div>
                <button type="button" class="sidebar-close" onclick="toggleSidebar()" aria-label="Chiudi menu">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <nav class="sidebar-nav">
                <section class="sidebar-section">
                    <span class="sidebar-section-title">Principale</span>
                    <a asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door"></i>
                        <span>Home</span>
                    </a>
                    <a asp-controller="Home" asp-action="Info">
                        <i class="bi bi-info-circle"></i>
                        <span>Info</span>
                    </a>
                    <a href="https://www.p-service.it/index.html" target="_blank" rel="noopener">
                        <i class="bi bi-telephone"></i>
                        <span>Contatti</span>
                    </a>
                </section>

                @if (canUseOperations)
                {
                    <section class="sidebar-section">
                        <span class="sidebar-section-title">Operazioni</span>
                        <a asp-controller="Anagrafe" asp-action="Index">
                            <i class="bi bi-people"></i>
                            <span>Anagrafe</span>
                        </a>
                        <a asp-controller="Toponomi" asp-action="Index">
                            <i class="bi bi-signpost"></i>
                            <span>Toponomi</span>
                        </a>
                        @if (isAdminPrincipale)
                        {
                            <a asp-controller="IndirizziNormalizzati" asp-action="Index">
                                <i class="bi bi-map"></i>
                                <span>Vie Ente</span>
                            </a>
                        }
                        <a asp-controller="Utenze" asp-action="Index">
                            <i class="bi bi-droplet-half"></i>
                            <span>Utenze Idriche</span>
                        </a>
                        <a asp-controller="Report" asp-action="Index">
                            <i class="bi bi-file-earmark-bar-graph"></i>
                            <span>Elaborazioni</span>
                        </a>
                    </section>
                }

                @if (isAdmin)
                {
                    <section class="sidebar-section sidebar-admin-section">
                        <span class="sidebar-section-title">Opzioni Admin</span>
                        <a asp-controller="Anagrafe" asp-action="Upload">
                            <i class="bi bi-cloud-arrow-up"></i>
                            <span>Carica Anagrafe</span>
                        </a>
                        <a asp-controller="Utenze" asp-action="Upload">
                            <i class="bi bi-database-add"></i>
                            <span>Carica Utenze</span>
                        </a>
                        <a asp-controller="Elaborazione" asp-action="NewProcessing">
                            <i class="bi bi-play-circle"></i>
                            <span>Nuova Elaborazione</span>
                        </a>
                        <a asp-controller="Enti" asp-action="Index">
                            <i class="bi bi-building-gear"></i>
                            <span>Gestione Enti</span>
                        </a>
                        <a asp-controller="Account" asp-action="Show">
                            <i class="bi bi-person-gear"></i>
                            <span>Gestione Utenti</span>
                        </a>
                        <a asp-controller="Log" asp-action="Index">
                            <i class="bi bi-activity"></i>
                            <span>Diagnostica</span>
                        </a>
                        <a asp-controller="Home" asp-action="Attivita">
                            <i class="bi bi-clock-history"></i>
                            <span>Attività Recenti</span>
                        </a>
                        <a asp-controller="Statistiche" asp-action="Index">
                            <i class="bi bi-graph-up-arrow"></i>
                            <span>Statistiche</span>
                        </a>
                    </section>
                }
            </nav>

            @if (isLogged)
            {
                <div class="sidebar-user">
                    <i class="bi bi-person-circle"></i>
                    <div>
                        <strong>@username</strong>
                        <span>@role</span>
                    </div>
                </div>
            }
        </aside>

        <div class="overlay" id="overlay" onclick="toggleSidebar()"></div>
    </header>

    <!-- CONTENUTO PRINCIPALE -->
    <div class="container app-main-container">
        <main role="main" class="app-main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-app mt-auto">
        <div class="container-xxl footer-app__inner">
            <div class="footer-app__brand">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="footer-app__title">
                    <i class="bi bi-droplet-fill" aria-hidden="true"></i>
                    <span>Software BonusIdrici</span>
                </a>
                <span class="footer-app__subtitle">Gestione pratiche per Bonus Idrico</span>
            </div>

            <nav class="footer-app__nav" aria-label="Collegamenti footer">
                <a asp-area="" asp-controller="Home" asp-action="Info" class="footer-link">Info</a>
                <a href="https://www.p-service.it/index.html?#chisiamo" class="footer-link" target="_blank" rel="noopener">Chi siamo</a>
                <a href="https://www.p-service.it/index.html?#contattaci" class="footer-link" target="_blank" rel="noopener">Contatti</a>
            </nav>

            <div class="footer-app__copy">
                <span>&copy; 2026</span>
                <a href="https://www.p-service.it" target="_blank" rel="noopener" class="footer-link">Point Service S.r.l.</a>
                <span>Tutti i diritti riservati.</span>
            </div>
        </div>
    </footer>


    <!-- ✅ SCRIPT (ordinati e senza duplicati) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- DataTables -->
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.0.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.0.2/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.0.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.0.2/js/buttons.print.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.0.2/js/buttons.colVis.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.2/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.2/js/responsive.bootstrap5.min.js"></script>

    <!-- Script Sidebar -->
    <script>
        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("active");
            document.getElementById("overlay").classList.toggle("active");
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
