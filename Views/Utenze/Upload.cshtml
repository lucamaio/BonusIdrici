@{
    ViewData["Title"] = "Carica Utenze Idriche";
}

<main class="upload-page">
    <div class="upload-shell">
        <section class="upload-card">
            <header class="upload-hero upload-hero-cyan">
                <div class="upload-hero-copy">
                    <span class="upload-hero-icon"><i class="bi bi-droplet-half mt-3 mb-3"></i></span>
                    <div>
                        <p class="upload-kicker">Importazione dati</p>
                        <h1>Carica utenze idriche</h1>
                        <span>Importa il CSV delle forniture e crea la fotografia mensile dell'ente.</span>
                    </div>
                </div>
            </header>

            <div class="upload-body">
                <form asp-controller="Utenze" asp-action="Upload" method="post" enctype="multipart/form-data" class="upload-form" onsubmit="showUploadLoader()">
                    <section class="upload-section">
                        <div class="upload-section-heading">
                            <i class="bi bi-building"></i>
                            <div>
                                <h2>Ente e periodo</h2>
                                <p>La fotografia utenze viene collegata al mese selezionato.</p>
                            </div>
                        </div>

                        <div class="upload-grid">
                            <div class="upload-field upload-field-full">
                                <label for="selectedEnteId" class="form-label">Ente</label>
                                <select id="selectedEnteId" name="selectedEnteId" class="form-select" required>
                                    <option value="">Seleziona un ente</option>
                                    @if (ViewBag.Enti != null)
                                    {
                                        foreach (var ente in ViewBag.Enti)
                                        {
                                            <option value="@ente.id">@ente.nome</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="upload-field">
                                <label for="meseRiferimento" class="form-label">Mese riferimento</label>
                                <select id="meseRiferimento" name="meseRiferimento" class="form-select" required>
                                    <option value="">Seleziona mese</option>
                                    @for (var mese = 1; mese <= 12; mese++)
                                    {
                                        <option value="@mese">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(mese)</option>
                                    }
                                </select>
                            </div>

                            <div class="upload-field">
                                <label for="annoRiferimento" class="form-label">Anno riferimento</label>
                                <input type="number" id="annoRiferimento" name="annoRiferimento" class="form-control" min="2021" max="@(DateTime.Now.Year + 1)" value="@DateTime.Now.Year" required>
                            </div>
                        </div>
                    </section>

                    <section class="upload-section">
                        <div class="upload-section-heading">
                            <i class="bi bi-filetype-csv"></i>
                            <div>
                                <h2>File utenze</h2>
                                <p>Il file deve essere in formato CSV.</p>
                            </div>
                        </div>

                        <div class="upload-file-zone upload-field">
                            <label for="csv_file" class="form-label">File CSV</label>
                            <input id="csv_file" type="file" name="csv_file" class="form-control" required accept=".csv">
                            <div class="upload-hint">Il caricamento usa le intestazioni del tracciato quando disponibili.</div>
                        </div>
                    </section>

                    <div class="upload-info">
                        <i class="bi bi-info-circle-fill"></i>
                        <span>Reimportando lo stesso ente e periodo, la fotografia delle forniture verra sostituita.</span>
                    </div>

                    <div class="upload-actions">
                        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Annulla</span>
                        </a>
                        <button type="submit" class="btn upload-submit">
                            <i class="bi bi-cloud-arrow-up-fill"></i>
                            <span>Carica file</span>
                        </button>
                    </div>
                </form>

                <div id="loader" class="upload-loader" role="status" aria-live="polite">
                    <div class="spinner-border text-primary" aria-hidden="true"></div>
                    <span>Elaborazione in corso, attendere...</span>
                </div>

                @if (!string.IsNullOrEmpty(ViewBag.Message))
                {
                    <div class="alert alert-info upload-message" role="alert">
                        <i class="bi bi-info-circle me-2"></i>@ViewBag.Message
                    </div>
                }
            </div>
        </section>
    </div>
</main>

@section Scripts {
    <script>
        function showUploadLoader() {
            document.getElementById("loader")?.classList.add("is-visible");
        }
    </script>
}
