@model IEnumerable<Models.ViewModels.UtenzeViewModel>

@{
    ViewData["Title"] = "Utenze Ente";
    var selectedEnteId = ViewBag.SelectedEnteId;
    var selectedEnteNome = ViewBag.SelectedEnteNome;
    var sectionActivity = ViewBag.SectionActivity as Models.ViewModels.SectionActivitySummaryViewModel;
}

<main class="data-page">
    <section class="data-hero data-hero-cyan">
        <div>
            <p>Utenze idriche ente</p>
            <h1>@selectedEnteNome</h1>
            <span>ID Ente: @selectedEnteId</span>
        </div>
        <div class="data-hero-actions">
            <a href="@Url.Action("Create", "Utenze", new { idEnte = selectedEnteId })" class="btn data-primary-action">
                <i class="bi bi-plus-circle"></i>
                <span>Aggiungi utenza</span>
            </a>
            <a href="@Url.Action("Snapshot", "Utenze", new { selectedEnteId = selectedEnteId })" class="btn btn-outline-light">
                <i class="bi bi-clock-history"></i>
                <span>Snapshot</span>
            </a>
            @if (ViewBag.Ruolo == "ADMIN" && ViewBag.idUser == 1)
            {
                <a href="@Url.Action("EsportaCsv", "Utenze", new { selectedEnteId = selectedEnteId })" class="btn btn-outline-light">
                    <i class="bi bi-download"></i>
                    <span>Esporta CSV</span>
                </a>
            }
        </div>
    </section>

    <section class="data-stats-grid data-stats-grid-wide">
        @{
            var stats = new[]
            {
                new { Icon = "bi-droplet-fill", Label = "Totale utenze", Value = ViewBag.TotaleUtenze, Tone = "stat-blue" },
                new { Icon = "bi-person-plus-fill", Label = "Iscrivendo/Iscritti", Value = ViewBag.UtenzeIscrivendo, Tone = "stat-green" },
                new { Icon = "bi-person-dash-fill", Label = "Cancellando/Cancellate", Value = ViewBag.UtenzeCancellate, Tone = "stat-red" },
                new { Icon = "bi-arrow-repeat", Label = "Iscrivendo/Cancellando", Value = ViewBag.UtenzeIscrivendoCancellando, Tone = "stat-amber" },
                new { Icon = "bi-house-fill", Label = "Domestiche", Value = ViewBag.UtenzeDomestiche, Tone = "stat-blue" },
                new { Icon = "bi-building-fill", Label = "Non domestiche", Value = ViewBag.UtenzeNonDomestiche, Tone = "stat-slate" }
            };
        }
        @foreach (var stat in stats)
        {
            <article class="data-stat-card @stat.Tone">
                <i class="bi @stat.Icon"></i>
                <span>@stat.Label</span>
                <strong>@stat.Value</strong>
            </article>
        }
    </section>

    @if (sectionActivity != null)
    {
        @await Html.PartialAsync("_SectionActivityPanel", sectionActivity)
    }

    <section class="data-table-card">
        <div class="data-table-header">
            <div>
                <p>Archivio utenze</p>
                <h2>Contatori, titolari e stato utenza</h2>
            </div>
            <span>Verifica i dati prima della generazione dei report</span>
        </div>

        <div id="loadingBarContainer" class="progress rounded-0" style="height: 6px; display: none;">
            <div id="loadingBar" class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                 role="progressbar" style="width: 0%"></div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive w-100" id="tableWrapper" style="display: none;">
                <table id="utenzeTable" class="table table-hover align-middle data-table w-100">
                    <thead>
                        <tr>
                            <th>Id Acquedotto</th>
                            <th>Matricola</th>
                            <th>Detentore</th>
                            <th>Ubicazione</th>
                            <th>Tipo</th>
                            <th>Stato</th>
                            <th class="text-center">Azioni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var detentore = FunzioniTrasversali.MaiuscoleIniziali((item.cognome + " " + item.nome).Trim());
                            var sito = FunzioniTrasversali.MaiuscoleIniziali(item.indirizzoUbicazione + ", " + item.numeroCivico);
                            var statoUtenza = FunzioniTrasversali.getStatoStringUtenza(item.stato);
                            var tipoUtenza = item.tipoUtenza switch
                            {
                                "UTENZA NON DOMESTICA" => "Non domestica",
                                "UTENZA DOMESTICA" => "Domestica",
                                "UTENZA COMMERCIALE" => "Commerciale",
                                "UTENZA USO ARTIGIANALE" => "Uso artigianale",
                                "UTENZA SPECIALE TEMPORANEA" => "Speciale temporanea",
                                "UTENZA USO INDUSTRIALE" => "Uso industriale",
                                _ => item.tipoUtenza
                            };

                            <tr>
                                <td><span class="data-code">@item.idAcquedotto</span></td>
                                <td>@item.matricolaContatore</td>
                                <td>
                                    <div class="data-main-cell">
                                        <strong>@detentore</strong>
                                        <span>ID @item.id</span>
                                    </div>
                                </td>
                                <td>@sito</td>
                                <td>@tipoUtenza</td>
                                <td><span class="data-status status-info">@statoUtenza</span></td>
                                <td class="text-center">
                                    <a class="data-icon-button" title="Modifica utenza"
                                       href="@Url.Action("Modifica", "Utenze", new { id = item.id })">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="data-empty-state">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Nessuna utenza trovata</strong>
                <span>Non risultano utenze idriche registrate per l'ente selezionato.</span>
            </div>
        }
    </section>

    <div class="data-bottom-actions">
        @if (ViewBag.Ruolo != "OPERATORE")
        {
            <a href="@Url.Action("Index", "Utenze")" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left-circle"></i>
                <span>Torna alla selezione ente</span>
            </a>
        }
        else
        {
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left-circle"></i>
                <span>Torna alla home</span>
            </a>
        }
    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#loadingBarContainer").show();
            var progress = 0;
            var interval = setInterval(function () {
                if (progress < 90) {
                    progress += 10;
                    $("#loadingBar").css("width", progress + "%");
                }
            }, 300);

            var utenzeTable = $('#utenzeTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                responsive: true,
                pageLength: 25,
                lengthMenu: [10, 25, 50, 100],
                language: { url: "https://cdn.datatables.net/plug-ins/2.0.8/i18n/it-IT.json" },
                dom: '<"d-flex justify-content-between align-items-center mb-3"l f>t<"row mt-3"<"col-sm-6"i><"col-sm-6 text-end"p>>',
                buttons: [],
                drawCallback: function (settings) {
                    var api = this.api();
                    var pages = api.page.info().pages;
                    if (pages <= 1) {
                        $(api.table().container()).find('.dataTables_paginate').hide();
                        $(api.table().container()).find('.dataTables_length').hide();
                    } else {
                        $(api.table().container()).find('.dataTables_paginate').show();
                        $(api.table().container()).find('.dataTables_length').show();
                    }
                }
            });

            utenzeTable.on('init', function () {
                clearInterval(interval);
                $("#loadingBar").css("width", "100%");
                setTimeout(function () {
                    $("#loadingBarContainer").fadeOut();
                    $("#tableWrapper").fadeIn();
                }, 500);
            });
        });
    </script>
}
