@{
    ViewData["Title"] = "Genera Risultati";
    var mesi = ViewBag.Mesi;
}

<main class="upload-page">
    <div class="upload-shell">
        <section class="upload-card">
            <header class="upload-hero upload-hero-red">
                <div class="upload-hero-copy">
                    <span class="upload-hero-icon"><i class="bi bi-file-earmark-bar-graph-fill mt-3 mb-3"></i></span>
                    <div>
                        <p class="upload-kicker">Elaborazione INPS</p>
                        <h1>Nuova elaborazione</h1>
                        <span>Importa il CSV INPS e genera gli esiti per il periodo selezionato.</span>
                    </div>
                </div>
            </header>

            <div class="upload-body">
                <form asp-controller="Elaborazione" asp-action="Processing" method="post" enctype="multipart/form-data" class="upload-form" onsubmit="return validateUploadForm()">
                    <section class="upload-section">
                        <div class="upload-section-heading">
                            <i class="bi bi-building"></i>
                            <div>
                                <h2>Dati elaborazione</h2>
                                <p>Ente, periodo e serie da associare al report.</p>
                            </div>
                        </div>

                        <div class="upload-grid upload-grid-three">
                            <div class="upload-field">
                                <label for="selectedEnteId" class="form-label">Ente</label>
                                <select class="form-select" id="selectedEnteId" name="selectedEnteId" required>
                                    <option value="">Seleziona un ente</option>
                                    @if (ViewBag.Enti != null)
                                    {
                                        foreach (var ente in ViewBag.Enti)
                                        {
                                            <option value="@ente.id">@ente.nome</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="upload-field">
                                <label for="mese" class="form-label">Mese</label>
                                <select class="form-select" id="mese" name="mese" required>
                                    <option value="">Seleziona mese</option>
                                    @if (mesi != null)
                                    {
                                        foreach (var month in mesi)
                                        {
                                            <option value="@month">@month</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="upload-field">
                                <label for="anno" class="form-label">Anno</label>
                                <input type="text" class="form-control" id="anno" name="anno" minlength="4" maxlength="4" value="@DateTime.Now.Year" required>
                            </div>

                            <div class="upload-field">
                                <label for="serie" class="form-label">Serie</label>
                                <input type="text" class="form-control" id="serie" name="serie" min="0" max="5">
                                <div class="upload-hint">Se vuota, viene usata la serie predefinita dell'ente.</div>
                            </div>
                        </div>
                    </section>

                    <section class="upload-section">
                        <div class="upload-section-heading">
                            <i class="bi bi-filetype-csv"></i>
                            <div>
                                <h2>File INPS</h2>
                                <p>Carica il flusso CSV da elaborare.</p>
                            </div>
                        </div>

                        <div class="upload-file-zone upload-field">
                            <label for="csv_file" class="form-label">File CSV INPS</label>
                            <input type="file" id="csv_file" name="csv_file" class="form-control" required accept=".csv">
                            <div class="upload-hint">Il periodo puo' essere letto dal nome file quando contiene il pattern previsto.</div>
                        </div>
                    </section>

                    <section class="upload-section">
                        <div class="upload-section-heading">
                            <i class="bi bi-sliders"></i>
                            <div>
                                <h2>Opzioni controllo</h2>
                                <p>Impostazioni applicate al confronto dei dati.</p>
                            </div>
                        </div>

                        <div class="upload-checks">
                            <div class="upload-check">
                                <input type="checkbox" id="confrontoCivico" name="confrontoCivico" class="form-check-input" value="true">
                                <label for="confrontoCivico" class="form-check-label">Confronta numero civico</label>
                            </div>

                            <div class="upload-check">
                                <input type="checkbox" id="escludiComponenti" name="escludiComponenti" class="form-check-input" value="true">
                                <label for="escludiComponenti" class="form-check-label">Escludi incongruenze relative al numero dei componenti del nucleo familiare</label>
                            </div>
                        </div>

                        <div class="upload-check">
                            <input type="checkbox" id="escludiAlertSnapshot" name="escludiAlertSnapshot" class="form-check-input" value="true">

                            <label for="escludiAlertSnapshot" class="form-check-label">
                                Escludi gli avvisi relativi alla mancanza degli snapshot anagrafici o delle utenze per il mese/anno di riferimento.
                                In assenza dello snapshot, la verifica verrà effettuata utilizzando i dati correnti.
                            </label>
                        </div>
                    </section>

                    <div class="upload-info">
                        <i class="bi bi-info-circle-fill"></i>
                        <span>Le opzioni selezionate influenzano i controlli su indirizzo, civico e composizione familiare.</span>
                    </div>

                    <div class="upload-actions">
                        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Annulla</span>
                        </a>
                        <button type="submit" class="btn upload-submit">
                            <i class="bi bi-play-circle-fill"></i>
                            <span>Elabora</span>
                        </button>
                    </div>
                </form>

                <div id="loader" class="upload-loader" role="status" aria-live="polite">
                    <div class="spinner-border text-primary" aria-hidden="true"></div>
                    <span>Elaborazione in corso, attendere...</span>
                </div>

                @if (!string.IsNullOrEmpty(ViewBag.Message))
                {
                    <div class="alert alert-info upload-message text-center" role="alert">
                        <i class="bi bi-info-circle me-2"></i>@ViewBag.Message
                    </div>
                }
            </div>
        </section>
    </div>
</main>

@section Scripts {
    <script>
        function validateUploadForm() {
            const form = document.querySelector(".upload-form");

            if (!form.checkValidity()) {
                form.reportValidity();
                return false;
            }

            document.getElementById("loader")?.classList.add("is-visible");
            return true;
        }
    </script>
}
