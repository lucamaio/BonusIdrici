@{
    ViewData["Title"] = "Toponomi Ente";
    List<Toponimo>? toponimi = ViewBag.Toponimi;
    var selectedEnteId = ViewBag.SelectedEnteId;
    var selectedEnteNome = ViewBag.SelectedEnteNome;
    var sectionActivity = ViewBag.SectionActivity as Models.ViewModels.SectionActivitySummaryViewModel;
}

<main class="data-page">
    <section class="data-hero data-hero-blue">
        <div>
            <p>Toponomi ente</p>
            <h1>@selectedEnteNome</h1>
            <span>ID Ente: @selectedEnteId</span>
        </div>
        <div class="data-hero-actions">
            <a href="@Url.Action("Create", "Toponomi", new { idEnte = selectedEnteId })" class="btn data-primary-action">
                <i class="bi bi-plus-circle"></i>
                <span>Aggiungi toponimo</span>
            </a>
            @if (ViewBag.Ruolo == "ADMIN" && ViewBag.idUser == 1)
            {
                <a href="@Url.Action("EsportaCsv", "Toponomi", new { selectedEnteId = selectedEnteId })" class="btn btn-outline-light">
                    <i class="bi bi-download"></i>
                    <span>Esporta CSV</span>
                </a>
            }
        </div>
    </section>

    <section class="data-stats-grid">
        <article class="data-stat-card">
            <i class="bi bi-signpost-fill"></i>
            <span>Totale toponimi</span>
            <strong>@ViewBag.TotaleToponomi</strong>
        </article>
        <article class="data-stat-card">
            <i class="bi bi-check2-circle"></i>
            <span>Normalizzati</span>
            <strong>@ViewBag.ToponomiNormalizzati</strong>
        </article>
        <article class="data-stat-card">
            <i class="bi bi-exclamation-circle"></i>
            <span>Da normalizzare</span>
            <strong>@ViewBag.ToponomiNoNormalizzazione</strong>
        </article>
    </section>

    @if (sectionActivity != null)
    {
        @await Html.PartialAsync("_SectionActivityPanel", sectionActivity)
    }

    <section class="data-table-card">
        <div class="data-table-header">
            <div>
                <p>Archivio toponomastico</p>
                <h2>Denominazioni e normalizzazioni</h2>
            </div>
            <span>Controlla gli indirizzi prima delle elaborazioni</span>
        </div>

        <div id="loadingBarContainer" class="progress rounded-0" style="height: 6px; display: none;">
            <div id="loadingBar" class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                 role="progressbar" style="width: 0%"></div>
        </div>

        @if (toponimi != null && toponimi.Count > 0)
        {
            <div class="table-responsive w-100" id="tableWrapper" style="display: none;">
                <table id="toponomiTable" class="table table-hover align-middle data-table w-100">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Denominazione</th>
                            <th>Normalizzazione</th>
                            <th>Tipo</th>
                            <th>Data Creazione</th>
                            <th class="text-center">Azioni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var toponimo in toponimi)
                        {
                            var tipoToponimo = toponimo.tipoToponimo ?? "N/D";
                            var normalizzazione = string.IsNullOrWhiteSpace(toponimo.normalizzazione) ? "Da completare" : toponimo.normalizzazione;
                            <tr>
                                <td><span class="data-code">@toponimo.id</span></td>
                                <td>
                                    <div class="data-main-cell">
                                        <strong>@toponimo.denominazione</strong>
                                        <span>Toponimo ente</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="data-status @(string.IsNullOrWhiteSpace(toponimo.normalizzazione) ? "status-warning" : "status-success")">
                                        @normalizzazione
                                    </span>
                                </td>
                                <td>@tipoToponimo</td>
                                <td>@toponimo.dataCreazione?.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">
                                    <a class="data-icon-button" title="Modifica toponimo"
                                       href="@Url.Action("Modifica", "Toponomi", new { id = toponimo.id })">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="data-empty-state">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Nessun toponimo trovato</strong>
                <span>Non risultano toponimi registrati per l'ente selezionato.</span>
            </div>
        }
    </section>

    <div class="data-bottom-actions">
        @if (ViewBag.Ruolo != "OPERATORE")
        {
            <a href="@Url.Action("Index", "Toponomi")" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left-circle"></i>
                <span>Torna alla selezione ente</span>
            </a>
        }
        else
        {
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left-circle"></i>
                <span>Torna alla home</span>
            </a>
        }
    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#loadingBarContainer").show();
            var progress = 0;
            var interval = setInterval(function () {
                if (progress < 90) {
                    progress += 10;
                    $("#loadingBar").css("width", progress + "%");
                }
            }, 300);

            var toponomiTable = $('#toponomiTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                responsive: true,
                pageLength: 25,
                lengthMenu: [10, 25, 50, 100],
                language: { url: "https://cdn.datatables.net/plug-ins/2.0.8/i18n/it-IT.json" },
                dom: '<"d-flex justify-content-between align-items-center mb-3"l f>t<"row mt-3"<"col-sm-6"i><"col-sm-6 text-end"p>>',
                drawCallback: function (settings) {
                    var api = this.api();
                    var pages = api.page.info().pages;
                    if (pages <= 1) {
                        $(api.table().container()).find('.dataTables_paginate').hide();
                        $(api.table().container()).find('.dataTables_length').hide();
                    } else {
                        $(api.table().container()).find('.dataTables_paginate').show();
                        $(api.table().container()).find('.dataTables_length').show();
                    }
                }
            });

            toponomiTable.on('init', function () {
                clearInterval(interval);
                $("#loadingBar").css("width", "100%");
                setTimeout(function () {
                    $("#loadingBarContainer").fadeOut();
                    $("#tableWrapper").fadeIn();
                }, 500);
            });
        });
    </script>
}
