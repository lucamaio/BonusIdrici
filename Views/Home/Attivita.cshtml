@model Models.ViewModels.AdminActivityDashboardViewModel

@{
    ViewData["Title"] = "Attivita Admin";
}

<main class="admin-activity-page">
    <section class="data-hero data-hero-blue">
        <div>
            <p>Area ADMIN</p>
            <h1>Ultime modifiche e operazioni</h1>
            <span>Riepilogo generato il @Model.GeneratedAt.ToString("dd/MM/yyyy HH:mm")</span>
        </div>
        <div class="data-hero-actions">
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary">
                <i class="bi bi-house-door"></i>
                <span>Home</span>
            </a>
        </div>
    </section>

    <section class="admin-activity-grid">
        @foreach (var activitySection in Model.Sections)
        {
            <article class="admin-activity-card">
                <div class="section-activity-feed-header">
                    <div>
                        <p>@activitySection.SectionName</p>
                        <h4>Operazioni recenti</h4>
                    </div>
                    <span>Ultime @activitySection.RecentActivities.Count</span>
                </div>

                <div class="admin-activity-last-update">
                    <i class="bi bi-clock-history"></i>
                    <span>Ultimo aggiornamento: <strong>@(activitySection.LastUpdate?.ToString("dd/MM/yyyy HH:mm") ?? "Nessun dato")</strong></span>
                </div>

                @if (activitySection.RecentActivities.Any())
                {
                    <ul class="admin-activity-list">
                        @foreach (var activity in activitySection.RecentActivities)
                        {
                            var routeValues = activity.RouteId.HasValue
                                ? new Dictionary<string, object?> { [activity.RouteParameterName] = activity.RouteId }
                                : null;

                            <li>
                                <span class="section-activity-icon @activity.Tone">
                                    <i class="bi @activity.Icon"></i>
                                </span>
                                <div>
                                    <div class="section-activity-row">
                                        <strong>@activity.Operation</strong>
                                        <time>@activity.Timestamp?.ToString("dd/MM/yyyy HH:mm")</time>
                                    </div>
                                    <p>@activity.Title</p>
                                    @if (!string.IsNullOrWhiteSpace(activity.Detail))
                                    {
                                        <small>@activity.Detail</small>
                                    }
                                </div>
                                @if (routeValues != null)
                                {
                                    <a class="section-activity-link"
                                       href="@Url.Action(activity.Action, activity.Controller, routeValues)"
                                       title="Apri dettaglio">
                                        <i class="bi bi-arrow-up-right"></i>
                                    </a>
                                }
                            </li>
                        }
                    </ul>

                    <div class="admin-diagnostic-actions">
                        <a class="btn btn-sm btn-outline-primary"
                           href="@Url.Action("AttivitaDettaglio", "Home", new { sezione = activitySection.SectionKey })">
                            <i class="bi bi-search"></i>
                            Esplora dettaglio
                        </a>
                    </div>
                }
                else
                {
                    <div class="section-activity-empty">
                        <i class="bi bi-info-circle"></i>
                        <span>Nessuna operazione registrata.</span>
                    </div>
                }
            </article>
        }
    </section>

    <section class="admin-diagnostic-activity">
        <div class="data-table-header">
            <div>
                <p>Diagnostica</p>
                <h2>Log recenti per categoria</h2>
            </div>
            <span>Ultimi 5 eventi per livello</span>
        </div>

        <div class="admin-diagnostic-grid">
            @foreach (var diagnosticSection in Model.DiagnosticActivities)
            {
                <article class="admin-diagnostic-card">
                    <div class="section-activity-feed-header">
                        <div>
                            <p>@diagnosticSection.Level</p>
                            <h4>
                                <span class="section-activity-icon @diagnosticSection.Tone">
                                    <i class="bi @diagnosticSection.Icon"></i>
                                </span>
                                @diagnosticSection.Title
                            </h4>
                        </div>
                        <span>@diagnosticSection.TotalCount eventi</span>
                    </div>

                    @if (diagnosticSection.RecentEvents.Any())
                    {
                        <ul class="admin-activity-list admin-diagnostic-list">
                            @foreach (var logEvent in diagnosticSection.RecentEvents)
                            {
                                <li>
                                    <span class="section-activity-icon @diagnosticSection.Tone">
                                        <i class="bi @diagnosticSection.Icon"></i>
                                    </span>
                                    <div>
                                        <div class="section-activity-row">
                                            <strong>@logEvent.SourceTitle</strong>
                                            <time>@logEvent.Timestamp?.ToString("dd/MM/yyyy HH:mm")</time>
                                        </div>
                                        <p>@logEvent.Message</p>
                                    </div>
                                    <a class="section-activity-link"
                                       href="@Url.Action("Show", "Log", new { tipoLog = logEvent.SourceKey })"
                                       title="Esplora dettaglio">
                                        <i class="bi bi-arrow-up-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>

                        <div class="admin-diagnostic-actions">
                            <a class="btn btn-sm btn-outline-primary"
                               href="@Url.Action("ShowLevel", "Log", new { livello = diagnosticSection.Level })">
                                <i class="bi bi-search"></i>
                                Esplora dettaglio
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="section-activity-empty">
                            <i class="bi bi-info-circle"></i>
                            <span>Nessun evento @diagnosticSection.Title.ToLower() registrato.</span>
                        </div>
                    }
                </article>
            }
        </div>
    </section>
</main>
