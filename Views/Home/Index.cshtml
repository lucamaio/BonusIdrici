<div class="home-dashboard main-content d-flex flex-column">
    <section class="home-hero-panel">
        <div class="home-hero-copy">
            <p class="home-kicker">Cruscotto operativo</p>
            <h1>Gestione Bonus Idrico</h1>
            <p>Consulta archivi, verifica le utenze e segui le elaborazioni INPS da un unico punto di lavoro.</p>
        </div>
        <div class="home-hero-actions">
            <a class="btn btn-primary" asp-controller="Elaborazione" asp-action="NewProcessing">
                <i class="bi bi-play-circle"></i> Nuova elaborazione
            </a>
            <a class="btn btn-outline-primary" asp-controller="Home" asp-action="FAQ">
                <i class="bi bi-question-circle"></i> FAQ operative
            </a>
        </div>
    </section>

    <section class="home-glass-section">
        <div class="home-section-heading">
            <div>
                <span>Consultazione dati</span>
                <h2>Archivi e verifiche</h2>
            </div>
            <p>Accesso rapido agli archivi principali per controllare persone, forniture e indirizzi.</p>
        </div>

        <div class="home-actions-grid row g-4">
            <div class="col-md-6 col-lg-4">
                <a asp-controller="Anagrafe" asp-action="Index" class="text-decoration-none text-reset">
                    <div class="card card-home h-100 shadow-sm">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="icon-circle bg-success text-white me-3">
                                    <i class="fas fa-address-card"></i>
                                </div>
                                <h5 class="card-title mb-0">Anagrafe</h5>
                            </div>
                            <p class="card-text text-muted mt-auto">
                                Gestisci e consulta i dati anagrafici relativi agli enti di competenza.
                            </p>
                        </div>
                    </div>
                </a>
            </div>

            @* <div class="col-md-6 col-lg-4">
                <a asp-controller="Toponomi" asp-action="Index" class="text-decoration-none text-reset">
                    <div class="card card-home h-100 shadow-sm">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="icon-circle bg-primary text-white me-3">
                                    <i class="fas fa-map-marked-alt"></i>
                                </div>
                                <h5 class="card-title mb-0">Toponomi</h5>
                            </div>
                            <p class="card-text text-muted mt-auto">
                                Visualizza e amministra l'elenco completo dei toponimi associati a un ente.
                            </p>
                        </div>
                    </div>
                </a>
            </div> *@

            <div class="col-md-6 col-lg-4">
                <a asp-controller="Utenze" asp-action="Index" class="text-decoration-none text-reset">
                    <div class="card card-home h-100 shadow-sm">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="icon-circle bg-info text-white me-3">
                                    <i class="fas fa-water"></i>
                                </div>
                                <h5 class="card-title mb-0">Utenze Idriche</h5>
                            </div>
                            <p class="card-text text-muted mt-auto">
                                Consulta le utenze idriche registrate e verifica i dati collegati.
                            </p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-6 col-lg-4">
                <a asp-controller="IndirizziNormalizzati" asp-action="Index" class="text-decoration-none text-reset">
                    <div class="card card-home h-100 shadow-sm">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="icon-circle bg-primary text-white me-3">
                                    <i class="fas fa-map-marked-alt"></i>
                                </div>
                                <h5 class="card-title mb-0">Indirizzi Normalizzati</h5>
                            </div>
                            <p class="card-text text-muted mt-auto">
                                Visualizza e amministra l'elenco completo degli indirizzi normalizzati associati a un ente.
                            </p>
                        </div>
                    </div>
                </a>
            </div>

            
        </div>
    </section>

    <section class="home-glass-section home-glass-section-blue">
        <div class="home-section-heading">
            <div>
                <span>Elaborazioni</span>
                <h2>Flussi INPS e report</h2>
            </div>
            <p>Avvia nuove elaborazioni e consulta l'esito dei report prodotti.</p>
        </div>

        <div class="home-actions-grid row g-4">
            <div class="col-md-6 col-lg-4">
                <a asp-controller="Elaborazione" asp-action="NewProcessing" class="text-decoration-none text-reset">
                    <div class="card card-home h-100 shadow-sm">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="icon-circle bg-danger text-white me-3">
                                    <i class="fas fa-file-invoice"></i>
                                </div>
                                <h5 class="card-title mb-0">Nuova Elaborazione</h5>
                            </div>
                            <p class="card-text text-muted mt-auto">
                                Avvia una nuova elaborazione importando il file CSV INPS.
                            </p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-6 col-lg-4">
                <a asp-controller="Report" asp-action="Index" class="text-decoration-none text-reset">
                    <div class="card card-home h-100 shadow-sm">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="icon-circle bg-danger text-white me-3">
                                    <i class="fas fa-chart-line"></i>
                                </div>
                                <h5 class="card-title mb-0">Elaborazioni</h5>
                            </div>
                            <p class="card-text text-muted mt-auto">
                                Esamina l'elenco delle elaborazioni effettuate e consulta le domande associate.
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </section>

    @if (ViewBag.Ruolo == "ADMIN")
    {
        <section class="home-glass-section home-admin-section">
            <div class="home-section-heading">
                <div>
                    <span>Amministratore</span>
                    <h2>Configurazione e diagnostica</h2>
                </div>
                <p>Strumenti riservati per caricamenti, utenti, enti, controlli e statistiche.</p>
            </div>

            <div class="home-actions-grid row g-4">
                <div class="col-md-6 col-lg-4">
                    <a asp-controller="Enti" asp-action="Index" class="text-decoration-none text-reset">
                        <div class="card card-home h-100 shadow-sm">
                            <div class="card-body d-flex flex-column p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="icon-circle bg-warning text-white me-3">
                                        <i class="fas fa-building"></i>
                                    </div>
                                    <h5 class="card-title mb-0">Gestione Enti</h5>
                                </div>
                                <p class="card-text text-muted mt-auto">
                                    Accedi alla gestione degli enti e aggiorna le configurazioni.
                                </p>
                            </div>
                        </div>
                    </a>
                </div>

