@{
    ViewData["Title"] = "Login";
}

<main class="login-page">
    <section class="login-shell">
        <div class="login-info-panel">
            <div class="login-brand-block">
                <span class="login-brand-mark">
                    <i class="bi bi-droplet-fill"></i>
                </span>
                <div>
                    <p class="login-kicker">Accesso riservato</p>
                    <h1>BonusIdrici</h1>
                </div>
            </div>
            <p class="login-info-copy">
                Gestisci pratiche, archivi anagrafici, utenze idriche ed elaborazioni INPS da un unico ambiente operativo.
            </p>
            <div class="login-info-list">
                <span><i class="bi bi-shield-check"></i> Sessione protetta</span>
                <span><i class="bi bi-database-check"></i> Dati centralizzati</span>
                <span><i class="bi bi-file-earmark-bar-graph"></i> Report e controlli</span>
            </div>
        </div>

        <div class="login-form-panel">
            <div class="login-form-heading">
                <span><i class="bi bi-person-lock"></i></span>
                <div>
                    <h2>Accedi</h2>
                    <p>Inserisci le tue credenziali per continuare.</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(TempData["Message"] as string))
            {
                <div class="login-alert">
                    <i class="bi bi-info-circle"></i>
                    <span>@TempData["Message"]</span>
                </div>
            }

            <form asp-controller="Login" asp-action="Accedi" method="POST" class="login-form">
                <div class="login-field">
                    <label for="username">Username o email</label>
                    <div class="login-input-wrap">
                        <i class="bi bi-person"></i>
                        <input type="text" id="username" name="username" autocomplete="username" required>
                    </div>
                </div>

                <div class="login-field">
                    <label for="password">Password</label>
                    <div class="login-input-wrap">
                        <i class="bi bi-key"></i>
                        <input type="password" id="password" name="password" autocomplete="current-password" aria-describedby="capsLockWarning" required>
                    </div>
                    <div id="capsLockWarning" class="login-caps-warning" role="alert" aria-live="polite" hidden>
                        <i class="bi bi-exclamation-triangle"></i>
                        <span>Caps Lock attivo: la password verra inserita in maiuscolo.</span>
                    </div>
                </div>

                <button type="submit" class="login-submit">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Entra nel sistema</span>
                </button>
            </form>
        </div>
    </section>
</main>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const passwordInput = document.getElementById('password');
            const capsLockWarning = document.getElementById('capsLockWarning');

            if (!passwordInput || !capsLockWarning) {
                return;
            }

            function updateCapsLockWarning(event) {
                const isCapsLockActive = event.getModifierState && event.getModifierState('CapsLock');
                capsLockWarning.hidden = !isCapsLockActive;
            }

            passwordInput.addEventListener('keydown', updateCapsLockWarning);
            passwordInput.addEventListener('keyup', updateCapsLockWarning);
            passwordInput.addEventListener('blur', function () {
                capsLockWarning.hidden = true;
            });
        });
    </script>
}
