@{
    ViewData["Title"] = "Dettagli Log";
    List<Log> rows = ViewBag.Logs;
    var logsList = rows ?? new List<Log>();
    var tipoLog = ViewBag.TipoLog as string ?? "Log";
}

<main class="data-page">
    <section class="data-hero data-hero-blue">
        <div>
            <p>Diagnostica</p>
            <h1>@tipoLog</h1>
            <span>Dettagli e messaggi del log selezionato</span>
        </div>
    </section>

    <section class="data-stats-grid">
        <article class="data-stat-card stat-blue">
            <i class="bi bi-activity"></i>
            <span>Righe log</span>
            <strong>@logsList.Count</strong>
        </article>
        <article class="data-stat-card stat-red">
            <i class="bi bi-exclamation-octagon-fill"></i>
            <span>Errori</span>
            <strong>@logsList.Count(x => x.TipoLog.Contains("ERROR", StringComparison.OrdinalIgnoreCase))</strong>
        </article>
        <article class="data-stat-card stat-amber">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>Warning</span>
            <strong>@logsList.Count(x => x.TipoLog.Contains("WARN", StringComparison.OrdinalIgnoreCase))</strong>
        </article>
    </section>

    <section class="data-table-card">
        <div class="data-table-header">
            <div>
                <p>Archivio log</p>
                <h2>Timestamp, livello e messaggio</h2>
            </div>
            <span>Ricerca, ordinamento e paginazione attivi</span>
        </div>

        <div id="loadingBarContainer" style="display: none;">
            <div id="loadingBar" role="progressbar"></div>
        </div>

        @if (logsList.Any())
        {
            <div class="table-responsive w-100" id="tableWrapper" style="display: none;">
                <table id="logsTable" class="table table-hover align-middle data-table w-100">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>Tipo Log</th>
                            <th>Messaggio</th>
                            <th class="text-center">Azioni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in logsList)
                        {
                            var statusClass = row.TipoLog.Contains("ERROR", StringComparison.OrdinalIgnoreCase)
                                ? "status-danger"
                                : row.TipoLog.Contains("WARN", StringComparison.OrdinalIgnoreCase)
                                    ? "status-warning"
                                    : "status-info";

                            <tr>
                                <td><span class="data-code">@row.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</span></td>
                                <td><span class="data-status @statusClass">@row.TipoLog</span></td>
                                <td>@row.GetShortMessage()</td>
                                <td class="text-center">
                                    <form asp-action="Dettails" method="post" class="d-inline">
                                        <input type="hidden" name="Timestamp" value="@row.Timestamp" />
                                        <input type="hidden" name="TipoLog" value="@row.TipoLog" />
                                        <input type="hidden" name="Messaggio" value="@row.Messaggio" />
                                        <button type="submit" class="data-icon-button" title="Dettagli log">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="data-empty-state">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Nessun log disponibile</strong>
                <span>Non risultano righe disponibili per il tipo di log selezionato.</span>
            </div>
        }
    </section>

    <div class="data-bottom-actions">
        <a href="@Url.Action("Index", "Log")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left-circle"></i>
            <span>Torna alla selezione</span>
        </a>
    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#loadingBarContainer").show();
            var progress = 0;
            var interval = setInterval(function () {
                if (progress < 90) {
                    progress += 10;
                    $("#loadingBar").css("width", progress + "%");
                }
            }, 300);

            var logsTable = $('#logsTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                responsive: true,
                pageLength: 25,
                lengthMenu: [10, 25, 50, 100],
                language: { url: "https://cdn.datatables.net/plug-ins/2.0.8/i18n/it-IT.json" },
                dom: '<"d-flex justify-content-between align-items-center mb-3"l f>t<"row mt-3"<"col-sm-6"i><"col-sm-6 text-end"p>>',
                buttons: [],
                drawCallback: function (settings) {
                    var api = this.api();
                    var pages = api.page.info().pages;
                    if (pages <= 1) {
                        $(api.table().container()).find('.dataTables_paginate').hide();
                        $(api.table().container()).find('.dataTables_length').hide();
                    } else {
                        $(api.table().container()).find('.dataTables_paginate').show();
                        $(api.table().container()).find('.dataTables_length').show();
                    }
                }
            });

            logsTable.on('init', function () {
                clearInterval(interval);
                $("#loadingBar").css("width", "100%");
                setTimeout(function () {
                    $("#loadingBarContainer").fadeOut();
                    $("#tableWrapper").fadeIn();
                }, 500);
            });
        });
    </script>
}
