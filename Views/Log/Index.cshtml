@model Models.ViewModels.LogDiagnosticViewModel
@{
    ViewData["Title"] = "Diagnostica";

    static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        var kb = bytes / 1024d;
        if (kb < 1024) return $"{kb:0.##} KB";
        return $"{kb / 1024d:0.##} MB";
    }
}

<div class="diagnostics-page">
    <div class="diagnostics-shell">
        <header class="diagnostics-hero">
            <div>
                <p class="diagnostics-kicker">Console amministratore</p>
                <h1>Diagnostica applicazione</h1>
                <span>Controlla lo stato dei log applicativi, gli ultimi eventi e le aree che richiedono attenzione.</span>
            </div>
            <a class="btn btn-outline-primary" asp-controller="Statistiche" asp-action="Index">
                <i class="bi bi-graph-up-arrow"></i> Statistiche
            </a>
        </header>

        <section class="diagnostics-summary" aria-label="Riepilogo diagnostica">
            <div>
                <i class="bi bi-folder2-open"></i>
                <span>File monitorati</span>
                <strong>@Model.TotalFiles</strong>
            </div>
            <div>
                <i class="bi bi-hdd"></i>
                <span>Spazio log</span>
                <strong>@FormatBytes(Model.TotalBytes)</strong>
            </div>
            <div>
                <i class="bi bi-list-ul"></i>
                <span>Righe totali</span>
                <strong>@Model.TotalRows</strong>
            </div>
            <div class="@(Model.TotalWarnings > 0 ? "has-warning" : "")">
                <i class="bi bi-exclamation-triangle"></i>
                <span>Warning</span>
                <strong>@Model.TotalWarnings</strong>
            </div>
            <div class="@(Model.TotalErrors > 0 ? "has-error" : "")">
                <i class="bi bi-x-octagon"></i>
                <span>Errori</span>
                <strong>@Model.TotalErrors</strong>
            </div>
        </section>

        <section class="diagnostics-panel">
            <div class="diagnostics-panel-heading">
                <div>
                    <h2><i class="bi bi-activity"></i> Stato dei log</h2>
                    <p>Nessuna selezione ente richiesta: la diagnostica riguarda l'intera applicazione.</p>
                </div>
                <span>Ultimo evento: @(Model.LastEvent?.ToString("dd/MM/yyyy HH:mm:ss") ?? "ND")</span>
            </div>

            <div class="diagnostics-grid">
                @foreach (var item in Model.Files)
                {
                    <article class="diagnostic-card @item.AccentClass">
                        <div class="diagnostic-card-head">
                            <i class="bi @item.Icon"></i>
                            <div>
                                <h3>@item.Title</h3>
                                <span>@item.Description</span>
                            </div>
                        </div>

                        <div class="diagnostic-status @item.Status">
                            <i class="bi @(item.Status == "danger" ? "bi-x-circle-fill" : item.Status == "warning" ? "bi-exclamation-circle-fill" : item.Status == "missing" ? "bi-dash-circle-fill" : "bi-check-circle-fill")"></i>
                            @item.StatusLabel
                        </div>

                        <dl class="diagnostic-metrics">
                            <div>
                                <dt>Dimensione</dt>
                                <dd>@item.SizeLabel</dd>
                            </div>
                            <div>
                                <dt>Righe</dt>
                                <dd>@item.Rows</dd>
                            </div>
                            <div>
                                <dt>Warning</dt>
                                <dd>@item.WarningCount</dd>
                            </div>
                            <div>
                                <dt>Errori</dt>
                                <dd>@item.ErrorCount</dd>
                            </div>
                        </dl>

                        <div class="diagnostic-footer">
                            <span>Ultimo evento: @(item.LastEvent?.ToString("dd/MM/yyyy HH:mm") ?? "ND")</span>
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Log" asp-action="Show" asp-route-tipoLog="@item.Key">
                                Apri dettagli
                            </a>
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>
</div>

<style>
    .diagnostics-page {
        background: #f5f7fb;
        min-height: calc(100vh - 80px);
        color: #172033;
    }

    .diagnostics-shell {
        width: min(1440px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0 46px;
    }

    .diagnostics-hero,
    .diagnostics-panel,
    .diagnostic-card,
    .diagnostics-summary div {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 10px 26px rgba(15, 23, 42, .06);
    }

    .diagnostics-hero {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 18px;
        padding: 22px;
        background:
            linear-gradient(135deg, rgba(255,255,255,.9), rgba(239,246,255,.72)),
            linear-gradient(90deg, rgba(37,99,235,.08), rgba(8,145,178,.06));
    }

    .diagnostics-kicker {
        margin: 0 0 6px;
        color: #2563eb;
        font-size: .76rem;
        font-weight: 850;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .diagnostics-hero h1 {
        margin: 0;
        font-size: clamp(1.8rem, 3vw, 2.7rem);
        font-weight: 850;
    }

    .diagnostics-hero span,
    .diagnostics-panel-heading p,
    .diagnostics-panel-heading span,
    .diagnostic-card-head span,
    .diagnostic-footer span,
    .diagnostic-metrics dt {
        color: #64748b;
    }

    .diagnostics-summary {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 12px;
        margin: 14px 0;
    }

    .diagnostics-summary div {
        min-height: 96px;
        padding: 14px;
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-areas: "icon label" "icon value";
        gap: 0 12px;
        align-items: center;
    }

    .diagnostics-summary i {
        grid-area: icon;
        width: 40px;
        height: 40px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: #eff6ff;
        color: #2563eb;
        font-size: 1.2rem;
    }

    .diagnostics-summary span {
        grid-area: label;
        color: #64748b;
        font-weight: 800;
        font-size: .86rem;
    }

    .diagnostics-summary strong {
        grid-area: value;
        font-size: 1.45rem;
        line-height: 1.1;
    }

    .diagnostics-summary .has-warning i {
        background: #fef3c7;
        color: #d97706;
    }

    .diagnostics-summary .has-error i {
        background: #fee2e2;
        color: #dc2626;
    }

    .diagnostics-panel {
        padding: 18px;
    }

    .diagnostics-panel-heading {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 14px;
    }

    .diagnostics-panel-heading h2 {
        margin: 0 0 4px;
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 1.25rem;
        font-weight: 850;
    }

    .diagnostics-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .diagnostic-card {
        padding: 16px;
        border-top: 4px solid var(--accent);
    }

    .diagnostic-card-head {
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .diagnostic-card-head > i {
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: var(--accent-bg);
        color: var(--accent);
        font-size: 1.25rem;
        flex: 0 0 auto;
    }

    .diagnostic-card h3 {
        margin: 0 0 3px;
        font-size: 1.05rem;
        font-weight: 850;
    }

    .diagnostic-status {
        width: fit-content;
        margin: 14px 0;
        padding: 5px 9px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-radius: 6px;
        font-weight: 850;
        font-size: .82rem;
    }

    .diagnostic-status.ok {
        background: #dcfce7;
        color: #166534;
    }

    .diagnostic-status.warning {
        background: #fef3c7;
        color: #92400e;
    }

    .diagnostic-status.danger,
    .diagnostic-status.missing {
        background: #fee2e2;
        color: #991b1b;
    }

    .diagnostic-metrics {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
        margin: 0;
    }

    .diagnostic-metrics div {
        padding: 8px;
        border-radius: 6px;
        background: #f8fafc;
    }

    .diagnostic-metrics dt {
        font-size: .72rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .diagnostic-metrics dd {
        margin: 2px 0 0;
        font-weight: 850;
    }

    .diagnostic-footer {
        margin-top: 14px;
        padding-top: 12px;
        border-top: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .diag-blue { --accent: #2563eb; --accent-bg: #eff6ff; }
    .diag-red { --accent: #dc2626; --accent-bg: #fef2f2; }
    .diag-cyan { --accent: #0891b2; --accent-bg: #ecfeff; }
    .diag-green { --accent: #16a34a; --accent-bg: #f0fdf4; }
    .diag-purple { --accent: #7c3aed; --accent-bg: #f5f3ff; }
    .diag-amber { --accent: #d97706; --accent-bg: #fffbeb; }

    @@media (max-width: 1000px) {
        .diagnostics-summary,
        .diagnostics-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .diagnostics-shell {
            width: min(100% - 20px, 1440px);
        }

        .diagnostics-hero,
        .diagnostics-panel-heading,
        .diagnostic-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .diagnostics-summary,
        .diagnostics-grid,
        .diagnostic-metrics {
            grid-template-columns: 1fr;
        }
    }
</style>
